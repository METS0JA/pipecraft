# metaMATE from source (no conda): https://github.com/tjcreedy/metamate

FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

ARG METAMATE_REF=v0.5.3
ARG BBMAP_VERSION=39.06
ARG SEQKIT_VERSION=2.8.1
ARG SEQKIT_ARCH=amd64

ENV METAMATE_REF=${METAMATE_REF}

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    default-jre-headless \
    mafft \
    python3 \
    python3-pip \
    r-base \
    r-cran-ape \
    r-cran-cluster \
    r-cran-fastcluster \
    r-cran-getopt \
    zlib1g-dev \
    libbz2-dev \
    liblzma-dev \
    libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/opt/bbmap:/usr/local/bin:${PATH}"

RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel \
    && python3 -m pip install --no-cache-dir numpy scipy biopython pysam

RUN curl -fsSL "https://sourceforge.net/projects/bbmap/files/BBMap_${BBMAP_VERSION}.tar.gz/download" \
    | tar -xz -C /opt \
    && test -d /opt/bbmap

RUN curl -fsSL "https://github.com/shenwei356/seqkit/releases/download/v${SEQKIT_VERSION}/seqkit_linux_${SEQKIT_ARCH}.tar.gz" \
    | tar -xz -C /usr/local/bin \
    && chmod +x /usr/local/bin/seqkit

RUN git clone --depth 1 --branch "${METAMATE_REF}" \
        https://github.com/tjcreedy/metamate.git /tmp/metamate \
    && python3 -m pip install --no-cache-dir /tmp/metamate \
    && rm -rf /tmp/metamate

RUN metamate --help >/dev/null

RUN mkdir -p /default_specs \
    && echo "[library; n; 0-1/2]" > /default_specs/specifications0.txt
